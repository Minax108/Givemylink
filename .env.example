# ─── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Instagram Credentials ───────────────────────────────────
BOT_INSTAGRAM_USERNAME=your_instagram_username
BOT_INSTAGRAM_PASSWORD=your_instagram_password

# ─── Instagram Session IDs (base64-encoded, comma-separated) ─
# Generate these using get_session.py
IG_SESSION_IDS=session1_base64,session2_base64

# ─── Optional: Proxy (for avoiding IP bans) ──────────────────
IG_PROXY=http://user:pass@ip:port

# ─── Optional: Playwright Relay Server (EC2) ─────────────────
# Required for reliable ManyChat postback button clicks
PW_RELAY_URL=http://your-ec2-ip:5123
PW_RELAY_API_KEY=your-secret-key-here

# ─── Debug Mode ──────────────────────────────────────────────
DEBUG_IG=0
